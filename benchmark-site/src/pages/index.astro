          <td data-i18n="apr_pcfg">PCFG + PII tags</td>
          <td class="num dim">—</td><td class="num">12.8%</td><td class="num">29.5%</td><td class="num dim">—</td>
        </tr>
        <tr>
          <td>RFGuess-PII</td>
          <td><span class="venue">USENIX Sec.&nbsp;2023</span></td>
          <td data-i18n="apr_rf">Random forest</td>
          <td class="num">7.3%</td><td class="num">24.1%</td><td class="num">48.7%</td><td class="num dim">—</td>
        </tr>
        <tr>
          <td>PointerGuess</td>
          <td><span class="venue">USENIX Sec.&nbsp;2024</span></td>
          <td data-i18n="apr_seq">Seq2Seq + pointer</td>
          <td class="num">8.2%</td><td class="num">25.2%</td><td class="num dim">—</td><td class="num dim">—</td>
        </tr>
