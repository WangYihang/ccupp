---
import Layout    from '../layouts/Layout.astro';
import Section   from '../components/Section.astro';
import Caption   from '../components/Caption.astro';
import Figure    from '../components/Figure.astro';
import KeyStrip  from '../components/KeyStrip.astro';

import { references } from '../data/benchmark';
import {
  PROFILE_ORDER,
  getMeasuredTools,
  getGenerationStats,
  getPiiEmbedding,
  getSuccessRates,
  getRankStats,
  getLengthDist,
} from '../data/loader';
import type { GenRow, PiiRow, LengthRow } from '../data/benchmark';
import { EN } from '../data/i18n';

const fmt  = (n: number): string => n.toLocaleString('en-US');
const pct  = (n: number): string => `${n.toFixed(1)}%`;
const opt  = (n: number | null, render: (x: number) => string): string => (n === null ? '—' : render(n));

const measuredTools = getMeasuredTools();

// Per-profile data assembled once for the render.
const PII_PROFILES = ['zh_full', 'zh_minimal', 'zh_medium'] as const;
const generation   = PROFILE_ORDER.map((p) => ({ profile: p, rows: getGenerationStats(p) }));
const piiEmbedding = PII_PROFILES.map((p) => ({ profile: p, rows: getPiiEmbedding(p) }));
const successRate  = getSuccessRates();
const rankStats    = getRankStats();
const lengthDist   = getLengthDist('zh_full');

const argmaxRows = <R,>(rows: R[], key: (r: R) => number | null): number => {
  let best = -Infinity, idx = -1;
  rows.forEach((r, i) => {
    const v = key(r);
    if (v !== null && v > best) { best = v; idx = i; }
  });
  return idx;
};

const genBest = (rows: GenRow[])         => argmaxRows(rows, (r) => r.pwd_per_s);
const piiBest = (rows: PiiRow[], field: keyof PiiRow) => argmaxRows(rows, (r) => r[field] as number);
const lenBest = (row: LengthRow)         => argmaxRows(measuredTools, (t) => row.counts[t] ?? 0);

const sr10Best  = argmaxRows(successRate, (r) => r.sr10);
const sr100Best = argmaxRows(successRate, (r) => r.sr100);
const sr1kBest  = argmaxRows(successRate, (r) => r.sr1k);
const sr10kBest = argmaxRows(successRate, (r) => r.sr10k);

const rankBestFound    = argmaxRows(rankStats, (r) => r.found);
const rankBestCoverage = argmaxRows(rankStats, (r) => r.coverage);

// Hero stats: pulled from CCUPP's measured numbers in JSON.
const ccuppSr = successRate.find((r) => r.method === 'CCUPP');
const ccuppRank = rankStats.find((r) => r.tool === 'CCUPP');
const ccuppZhFull = generation[0]?.rows.find((r) => r.tool === 'CCUPP');
const cuppZhFull  = generation[0]?.rows.find((r) => r.tool === 'CUPP');
const heroSr1k    = ccuppSr?.sr1k ?? 45.5;
const heroCov     = ccuppRank?.coverage ?? 84.0;
const heroSpeed   = ccuppZhFull ? (ccuppZhFull.pwd_per_s / 1_000_000) : 2.2;
const heroVsCupp  = ccuppZhFull && cuppZhFull && cuppZhFull.pwd_per_s
  ? ccuppZhFull.pwd_per_s / cuppZhFull.pwd_per_s
  : 9;
---

<Layout title="CCUPP — Benchmark Evaluation Report">

  <section class="title-block">
    <div class="eyebrow" data-i18n="eyebrow">{EN.eyebrow}</div>
    <h1 data-i18n="heading">{EN.heading}</h1>
    <div class="subtitle" data-i18n="subtitle">{EN.subtitle}</div>
    <div class="meta" data-i18n-html="meta" set:html={EN.meta}></div>
  </section>

  <p class="abstract" data-i18n-html="abstract" set:html={EN.abstract}></p>

  <Section n={1} k="s1" title={EN.s1} />

  <KeyStrip cells={[
    { value: heroSr1k.toFixed(1),   unit: '%',    labelKey: 'ks_sr',  label: EN.ks_sr  },
    { value: heroCov.toFixed(1),    unit: '%',    labelKey: 'ks_cov', label: EN.ks_cov },
    { value: heroSpeed.toFixed(1),  unit: ' M/s', labelKey: 'ks_gen', label: EN.ks_gen },
    { value: heroVsCupp.toFixed(0), unit: '×',    labelKey: 'ks_vs',  label: EN.ks_vs  },
  ]} />

  <Section n={2} k="s2" title={EN.s2} />

  <p data-i18n-html="s2_p" set:html={EN.s2_p}></p>

  <Caption label="Table 1" k="tbl1_cap" set:html={EN.tbl1_cap} />
  <div class="table-wrap">
    <table class="t-pair">
      <thead>
        <tr>
          <th data-i18n="th_profile">{EN.th_profile}</th>
          <th data-i18n="th_tool">{EN.th_tool}</th>
          <th class="num" data-i18n="th_passwords">{EN.th_passwords}</th>
          <th class="num" data-i18n-html="th_time" set:html={EN.th_time}></th>
          <th class="num" data-i18n="th_pps">{EN.th_pps}</th>
        </tr>
      </thead>
      <tbody>
        {generation.map((p) => {
          const winner = genBest(p.rows);
          return p.rows.map((r, i) => (
            <tr class={i === 0 ? 'group-start' : ''}>
              {i === 0 && <td rowspan={p.rows.length} class="label-col">{p.profile}</td>}
              <td><span class={`tool-tag${r.tool === 'CCUPP' ? ' ours' : ''}`}>{r.tool}</span></td>
              <td class="num">{fmt(r.passwords)}</td>
              <td class="num">{r.time_s.toFixed(3)}</td>
              <td class={`num${i === winner ? ' best' : ''}`}>{fmt(r.pwd_per_s)}</td>
            </tr>
          ));
        })}
      </tbody>
    </table>
  </div>

  <div class="figure-row">
    <Figure id="speedChart" label="Figure 1a" k="fig1a" set:html={EN.fig1a} />
    <Figure id="countChart" label="Figure 1b" k="fig1b" set:html={EN.fig1b} />
  </div>

  <Section n={3} k="s3" title={EN.s3} />

  <p data-i18n-html="s3_p" set:html={EN.s3_p}></p>

  <Caption label="Table 2" k="tbl2_cap" set:html={EN.tbl2_cap} />
  <div class="table-wrap">
    <table class="t-pair">
      <thead>
        <tr>
          <th data-i18n="th_profile">{EN.th_profile}</th>
          <th data-i18n="th_tool">{EN.th_tool}</th>
          <th class="num" data-i18n="th_name">{EN.th_name}</th>
          <th class="num" data-i18n="th_date">{EN.th_date}</th>
          <th class="num" data-i18n="th_phone">{EN.th_phone}</th>
          <th class="num" data-i18n="th_account">{EN.th_account}</th>
          <th class="num" data-i18n="th_overall">{EN.th_overall}</th>
        </tr>
      </thead>
      <tbody>
        {piiEmbedding.map((p) => {
          const bName    = piiBest(p.rows, 'name');
          const bDate    = piiBest(p.rows, 'date');
          const bPhone   = piiBest(p.rows, 'phone');
          const bAccount = piiBest(p.rows, 'account');
          const bOverall = piiBest(p.rows, 'overall');
          return p.rows.map((r, i) => (
            <tr class={i === 0 ? 'group-start' : ''}>
              {i === 0 && <td rowspan={p.rows.length} class="label-col">{p.profile}</td>}
              <td><span class={`tool-tag${r.tool === 'CCUPP' ? ' ours' : ''}`}>{r.tool}</span></td>
              <td class={`num${bName    === i ? ' best' : ''}`}>{pct(r.name)}</td>
              <td class={`num${bDate    === i ? ' best' : ''}`}>{pct(r.date)}</td>
              <td class={`num${bPhone   === i ? ' best' : ''}`}>{pct(r.phone)}</td>
              <td class={`num${bAccount === i ? ' best' : ''}`}>{pct(r.account)}</td>
              <td class={`num${bOverall === i ? ' best' : ''}`}>{pct(r.overall)}</td>
            </tr>
          ));
        })}
      </tbody>
    </table>
  </div>

  <Figure id="piiChart" label="Figure 2" k="fig2" height={150} set:html={EN.fig2} />

  <Section n={4} k="s4" title={EN.s4} />

  <p data-i18n-html="s4_p" set:html={EN.s4_p}></p>

  <Caption label="Table 3" k="tbl3_cap" set:html={EN.tbl3_cap} />
  <div class="table-wrap">
    <table class="t-row">
      <thead>
        <tr>
          <th data-i18n="th_method">{EN.th_method}</th>
          <th data-i18n="th_venue">{EN.th_venue}</th>
          <th data-i18n="th_approach">{EN.th_approach}</th>
          <th class="num">SR@10</th>
          <th class="num">SR@100</th>
          <th class="num">SR@1000</th>
          <th class="num">SR@10⁴</th>
        </tr>
      </thead>
      <tbody>
        {successRate.map((r, i) => (
          <tr class={r.ours ? 'row-mine' : ''}>
            <td>{r.ours ? <strong>{r.method}</strong> : r.method}</td>
            <td>{r.measured
              ? <span class="pill measured" data-i18n="lbl_measured">{EN.lbl_measured}</span>
              : <span class="venue">{r.venueKey}</span>}</td>
            <td data-i18n={r.approachKey}>{EN[r.approachKey as keyof typeof EN]}</td>
            <td class={`num${sr10Best  === i ? ' best' : ''}${r.sr10  === null ? ' dim' : ''}`}>{opt(r.sr10,  pct)}</td>
            <td class={`num${sr100Best === i ? ' best' : ''}${r.sr100 === null ? ' dim' : ''}`}>{opt(r.sr100, pct)}</td>
            <td class={`num${sr1kBest  === i ? ' best' : ''}${r.sr1k  === null ? ' dim' : ''}`}>{opt(r.sr1k,  pct)}</td>
            <td class={`num${sr10kBest === i ? ' best' : ''}${r.sr10k === null ? ' dim' : ''}`}>{opt(r.sr10k, pct)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <Figure id="srChart" label="Figure 3" k="fig3" height={200} set:html={EN.fig3} />

  <Section n={5} k="s5" title={EN.s5} />

  <p data-i18n-html="s5_p" set:html={EN.s5_p}></p>

  <Caption label="Table 4" k="tbl4_cap" set:html={EN.tbl4_cap} />
  <div class="table-wrap">
    <table class="t-row">
      <thead>
        <tr>
          <th data-i18n="th_tool">{EN.th_tool}</th>
          <th class="num" data-i18n="th_found">{EN.th_found}</th>
          <th class="num" data-i18n="th_missed">{EN.th_missed}</th>
          <th class="num" data-i18n="th_coverage">{EN.th_coverage}</th>
          <th class="num" data-i18n="th_min">{EN.th_min}</th>
          <th class="num" data-i18n="th_median">{EN.th_median}</th>
          <th class="num" data-i18n="th_mean">{EN.th_mean}</th>
          <th class="num" data-i18n="th_max">{EN.th_max}</th>
        </tr>
      </thead>
      <tbody>
        {rankStats.map((r, i) => (
          <tr class={r.tool === 'CCUPP' ? 'row-mine' : ''}>
            <td><span class={`tool-tag${r.tool === 'CCUPP' ? ' ours' : ''}`}>{r.tool}</span></td>
            <td class={`num${rankBestFound    === i ? ' best' : ''}`}>{fmt(r.found)}</td>
            <td class="num">{fmt(r.missed)}</td>
            <td class={`num${rankBestCoverage === i ? ' best' : ''}`}>{pct(r.coverage)}</td>
            <td class={`num${r.min    === null ? ' dim' : ''}`}>{opt(r.min,    fmt)}</td>
            <td class={`num${r.median === null ? ' dim' : ''}`}>{opt(r.median, fmt)}</td>
            <td class={`num${r.mean   === null ? ' dim' : ''}`}>{opt(r.mean,   fmt)}</td>
            <td class={`num${r.max    === null ? ' dim' : ''}`}>{opt(r.max,    fmt)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <p data-i18n-html="s5_p2" set:html={EN.s5_p2}></p>

  <Caption label="Table 5" k="tbl5_cap" set:html={EN.tbl5_cap} />
  <div class="table-wrap">
    <table class="t-row">
      <thead>
        <tr>
          <th data-i18n="th_length">{EN.th_length}</th>
          {measuredTools.map((t) => (
            <Fragment>
              <th class="num">{t}</th>
              <th class="num" data-i18n-html={`th_${t.toLowerCase()}_pct`}>{t} %</th>
            </Fragment>
          ))}
        </tr>
      </thead>
      <tbody>
        {lengthDist.map((r) => {
          const winner = lenBest(r);
          return (
            <tr>
              <td>{r.bin}</td>
              {measuredTools.map((t, i) => (
                <Fragment>
                  <td class={`num${i === winner ? ' best' : ''}`}>{fmt(r.counts[t] ?? 0)}</td>
                  <td class="num">{(r.pcts[t] ?? 0).toFixed(0)}%</td>
                </Fragment>
              ))}
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  <div class="figure-row">
    <Figure id="overlapChart" label="Figure 4a" k="fig4a" set:html={EN.fig4a} />
    <Figure id="lengthChart"  label="Figure 4b" k="fig4b" set:html={EN.fig4b} />
  </div>

  <Section n={6} k="s6" title={EN.s6} />

  <h3 data-i18n="s6_str">{EN.s6_str}</h3>
  <p data-i18n-html="s6_str_p" set:html={EN.s6_str_p}></p>

  <h3 data-i18n="s6_lim">{EN.s6_lim}</h3>
  <p data-i18n-html="s6_lim_p" set:html={EN.s6_lim_p}></p>

  <h3 data-i18n="s6_cav">{EN.s6_cav}</h3>
  <p data-i18n-html="s6_cav_p" set:html={EN.s6_cav_p}></p>

  <h3 data-i18n="s6_pos">{EN.s6_pos}</h3>
  <p data-i18n-html="s6_pos_p" set:html={EN.s6_pos_p}></p>

  <Section n={7} k="s7" title={EN.s7} />

  <div class="table-wrap">
    <table class="t-row">
      <thead>
        <tr>
          <th style="width:2.6em;">#</th>
          <th data-i18n="th_ref">{EN.th_ref}</th>
          <th data-i18n="th_venue">{EN.th_venue}</th>
        </tr>
      </thead>
      <tbody>
        {references.map((r) => (
          <tr>
            <td class="num dim">[{r.id}]</td>
            <td>{r.authors}, <em>{r.title}</em>.</td>
            <td><span class="venue">{r.venue}</span></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <footer class="paper-foot" data-i18n-html="footer" set:html={EN.footer}></footer>

</Layout>

<script>
  import { initCharts } from '../scripts/charts.client';
  import { setupI18n }  from '../scripts/i18n.client';

  /* Chart.js is loaded via <script src> in Layout.astro; wait for it. */
  function start(): void {
    if (typeof (window as any).Chart === 'undefined') {
      window.setTimeout(start, 30);
      return;
    }
    const charts = initCharts();
    setupI18n(charts);
  }
  start();
</script>
